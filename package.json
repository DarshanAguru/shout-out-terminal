{
  "name": "shout-out-terminal",
  "displayName": "Shout Out Terminal",
  "description": "🔊 Your terminal talks back! Get instant audio feedback for errors, build results, test outcomes, and more — right inside VS Code.",
  "version": "0.0.1",
  "publisher": "Darshan",
  "author": {
    "name": "Darshan",
    "url": "https://thisdarshiii.in"
  },
  "license": "MIT",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DarshanAguru/shout-out-terminal.git"
  },
  "bugs": {
    "url": "https://github.com/DarshanAguru/shout-out-terminal/issues"
  },
  "homepage": "https://github.com/DarshanAguru/shout-out-terminal",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "terminal",
    "audio",
    "sound",
    "feedback",
    "error",
    "build",
    "test",
    "notification",
    "productivity",
    "developer-tools"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "shout-out-terminal.helloWorld",
        "title": "Hello World"
      }
    ],
    "configuration": {
      "title": "Shout Out Terminal",
      "properties": {
        "shout-out-terminal.mode": {
          "type": "string",
          "default": "amature",
          "enum": [
            "amature",
            "mature"
          ],
          "enumDescriptions": [
            "Plays audio instantly as events are written to the terminal (real-time)",
            "Waits for the command to finish, then plays a single summary sound"
          ],
          "description": "Determines when audio feedback is played."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "play-sound": "^1.1.6",
    "serialize-javascript": "^7.0.4"
  }
}